    "http://localhost:4173/lessons",
    "http://localhost:4173/lessons/browser",
    "http://localhost:4173/quiz",
    "http://localhost:4173/flashcards",
    "http://localhost:4173/exercises",
    "http://localhost:4173/progress",
    "http://localhost:4173/achievements",
    "http://localhost:4173/settings",
    "http://localhost:4173/settings/profile",
    "http://localhost:4173/settings/preferences",
    "http://localhost:4173/settings/appearance"
  ]
}
