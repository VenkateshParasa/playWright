{
    "name": "playwright-learning/api-sdk",
    "description": "Official PHP SDK for the Playwright & Selenium Learning Platform API",
    "version": "1.0.0",
    "type": "library",
    "keywords": ["playwright", "selenium", "learning", "api", "sdk"],
    "license": "MIT",
    "authors": [
        {
            "name": "Playwright Learning Platform",
            "email": "api@playwright-learning.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "PlaywrightLearning\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PlaywrightLearning\\SDK\\Tests\\": "tests/"
        }
    }
}
